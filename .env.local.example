# Copy to .env.local and fill in.

# ── Vern API ───────────────────────────────────────────────────────────────────
# Where the migration API lives. Defaults to https://app.vern.so.
VERN_API_BASE=https://app.vern.so
# Only needed if VERN_API_BASE is behind Vercel Deployment Protection (e.g. staging).
VERN_PROTECTION_BYPASS=

# ── OpenAI sample CSV generation ───────────────────────────────────────────────
# Used only by the "Generate sample CSVs" button.
OPENAI_API_KEY=
# Optional. Defaults to gpt-5.4-mini (fast). Override to use a larger model.
OPENAI_SAMPLE_MODEL=

# ── Demo branding ──────────────────────────────────────────────────────────────
# Your Vern API key. Get one from https://docs.vern.so/migration-api/introduction
VERN_API_KEY=
# Optional branding for the single demo.
DEMO_PRODUCT=Acme
DEMO_BRAND_COLOR=#4F46E5
DEMO_LOGO_URL=
DEMO_SOURCE=
# Optional. Max number of completed imports allowed per demo. Defaults to 3.
DEMO_IMPORT_LIMIT=
# Optional access gate: comma-separated domains or exact emails. Empty = open.
DEMO_VERIFIED_EMAILS=

# ── Access gate ────────────────────────────────────────────────────────────────
# Secret for signing the session cookie. Required only when a gate is active.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEMO_SESSION_SECRET=

# ── Public links shown in the UI (optional) ────────────────────────────────────
NEXT_PUBLIC_SOURCE_URL=https://github.com/vern-so/vern-demos
NEXT_PUBLIC_BOOK_A_CALL_URL=https://cal.com/vishvarma/30min

# ── Slack notifications (optional) ─────────────────────────────────────────────
# Slack Incoming Webhook URL. When set, the app posts a message each time a
# visitor starts a demo migration. Leave empty to disable.
SLACK_WEBHOOK_URL=
